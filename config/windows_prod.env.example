# Windows Production Environment Configuration
ENVIRONMENT=production

# Base directory for content, logs, and config
# Leave empty to auto-detect (uses the project directory)
# Example: C:\Users\YourName\obs-digital-signage-system
CONTENT_BASE_DIR=

# OBS WebSocket Settings
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=  # OBS WebSocket password (set in OBS: Tools > WebSocket Server Settings)
OBS_TIMEOUT=10
OBS_STARTUP_DELAY=15

# WebDAV/Synology Settings
WEBDAV_HOST=
WEBDAV_PORT=5006
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_TIMEOUT=30
WEBDAV_SYNC_INTERVAL=30
WEBDAV_ROOT_PATH=/

# Media Settings
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
IMAGE_DISPLAY_TIME=15
MAX_VIDEO_DURATION=900
SLIDE_TRANSITION_SECONDS=15
TRANSITION_START_OFFSET=2.0

# Audio Settings
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=2
AUDIO_BUFFER_SIZE=1024

# Scheduling
# Schedules are managed through the web UI at http://<host>:8080
SCHEDULE_ENABLED=true
# Examples: UTC, Europe/Copenhagen, America/New_York, Europe/London, Asia/Tokyo
TIMEZONE=UTC
SCHEDULE_CHECK_INTERVAL=60
MANUAL_CONTENT_FOLDER=

# Web UI
# Admin panel accessible on http://<host>:<port>
WEB_UI_ENABLED=true
WEB_UI_PORT=8080

# Notifications (optional)
NOTIFICATION_ENABLED=false
NOTIFICATION_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
